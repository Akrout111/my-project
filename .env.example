# ── Database ──
DATABASE_URL="file:./dev.db"

# ── Authentication ──
JWT_SECRET="your-jwt-secret-min-32-chars"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/register"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ── KNet Payment Gateway ──
KNET_MERCHANT_ID="your-merchant-id"
KNET_TERMINAL_ID="your-terminal-id"
KNET_SECRET_KEY="your-secret-key"
KNET_RESOURCE_KEY="your-resource-key"
KNET_BASE_URL="https://kpaytest.com.kw"

# ── Cloudflare R2 Storage ──
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="your-bucket"
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# ── Email (Resend) ──
RESEND_API_KEY="re_..."
EMAIL_FROM="no-reply@kuwaitevents.com"

# ── Rate Limiting (Upstash Redis) ──
UPSTASH_REDIS_REST_URL="https://your-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ── App ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
